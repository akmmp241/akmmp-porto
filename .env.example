DATABASE_URL=postgres://postgres:postgres@localhost:5433/portfolio
PUBLIC_SITE_URL=http://localhost:5173
ORIGIN=http://localhost:5173
NODE_ENV=development
# GitHub Personal Access Token (read:user scope). Required for GitHub stats.
# Create at: https://github.com/settings/tokens/new?scopes=read:user,public_repo
GITHUB_TOKEN=your_github_pat_here

# Email Settings (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password
ADMIN_EMAIL=your-admin-email@gmail.com

