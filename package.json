		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^15.14.0",
		"postcss": "^8.4.0",
		"prettier": "^3.4.0",
		"prettier-plugin-svelte": "^3.3.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.16.0",
		"svelte-check": "^4.1.0",
		"tailwindcss": "^4.0.0",
		"tsx": "^4.22.4",
		"typescript": "^5.7.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.0.0"
